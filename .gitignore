# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.coverage
coverage.xml

# Virtual environments
.venv
.env

db
notebooks
.specstory
.claude

# Public OpenAPI spec fetched from the running app for client generation; never
# committed (the publish workflow curls it fresh from /public-api/openapi.json).
openapi/openapi.json
openapi/compiled.yaml

# Speakeasy generated client trees (per-target gen.yaml is committed).
.speakeasy/out/python/*
!.speakeasy/out/python/.speakeasy/
.speakeasy/out/cli/*
!.speakeasy/out/cli/.speakeasy/
.speakeasy/logs/
.speakeasy/workflow.lock
